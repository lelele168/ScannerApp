<?xml version="1.0" encoding="utf-8"?>
<!-- From: https://android.googlesource.com/platform/frameworks/base/+/master/core/res/res/drawable/edit_text_material.xml -->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:insetLeft="@dimen/abc_edit_text_inset_horizontal_material"
    android:insetRight="@dimen/abc_edit_text_inset_horizontal_material"
    android:insetTop="@dimen/abc_edit_text_inset_top_material"
    android:insetBottom="@dimen/abc_edit_text_inset_bottom_material">

    <selector>
        <!--
             This file is used for API 21 below to simulate the Material Design text field.
        -->
        <item android:state_enabled="false"
            android:drawable="@drawable/abc_textfield_default_mtrl_alpha"/>
        <item android:state_pressed="false"
            android:state_focused="false"
            android:drawable="@drawable/abc_textfield_default_mtrl_alpha"/>
        <item android:drawable="@drawable/abc_textfield_activated_mtrl_alpha"/>
    </selector>

</inset>
